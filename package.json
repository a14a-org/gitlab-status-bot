{
  "name": "gitlab-status-bot",
  "version": "1.0.0",
  "description": "A Slack bot that provides rich, interactive, and real-time status updates for GitLab CI/CD pipelines",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node-dev src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc -p tsconfig.test.json",
    "test:smoke": "playwright test tests/unit",
    "test:e2e": "playwright test tests/e2e"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/a14a-org/gitlab-status-bot.git"
  },
  "keywords": [
    "slack",
    "gitlab",
    "ci-cd",
    "bot",
    "typescript",
    "nodejs",
    "webhook",
    "pipeline",
    "status",
    "firestore",
    "cloud-run",
    "serverless"
  ],
  "author": "a14a-org",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/a14a-org/gitlab-status-bot/issues"
  },
  "homepage": "https://github.com/a14a-org/gitlab-status-bot#readme",
  "engines": {
    "node": ">=16.20.2"
  },
  "dependencies": {
    "@google-cloud/error-reporting": "^3.0.6",
    "@google-cloud/firestore": "^8.6.0",
    "@slack/bolt": "^4.7.3",
    "@slack/types": "^2.21.1",
    "axios": "^1.17.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "@playwright/test": "^1.60.0",
    "@biomejs/biome": "^2.4.16"
  }
}
